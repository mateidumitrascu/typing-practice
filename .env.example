# typepractice server configuration
#
# Copy to .env and adjust. Every value below shows its default; delete or
# comment out anything you don't need to change. Real environment variables
# always take precedence over this file.
#
# The format is plain KEY=value, so the same file works with systemd:
#   EnvironmentFile=/opt/typepractice/.env
# The server also loads it by itself from the working directory, or from the
# path in ENV_FILE if set.

# ---- server ----------------------------------------------------------------
# Address to listen on. Use 127.0.0.1:8080 in prod so only the Cloudflare
# tunnel on the Pi can reach it.
ADDR=:8080

# Mount path when served under the main site (e.g. /typing). Empty = root.
# Must match the cloudflared ingress rule and the web client's build base.
BASE_PATH=

# SQLite database file. Use an absolute path in prod.
DB_PATH=typepractice.db

# ---- logging ---------------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info
# text | json (json is handy if you ship logs somewhere structured)
LOG_FORMAT=text

# ---- http timeouts ---------------------------------------------------------
# Go duration strings: 10s, 2m, 1h30m ...
READ_TIMEOUT=10s
WRITE_TIMEOUT=30s
IDLE_TIMEOUT=2m
# Grace period for in-flight requests on SIGTERM (systemd stop/restart).
SHUTDOWN_TIMEOUT=10s

# ---- auth ------------------------------------------------------------------
# How long a login session lasts, in days.
SESSION_TTL_DAYS=30

# Login attempts allowed per IP within the window below.
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=1m

# Send the session cookie with the Secure flag. Keep true in prod (HTTPS via
# Cloudflare); set false only for plain-HTTP local development.
COOKIE_SECURE=true

# Header carrying the real client IP behind the proxy. CF-Connecting-IP for
# Cloudflare tunnels; set empty to trust the TCP peer address directly.
IP_HEADER=CF-Connecting-IP

# bcrypt cost for `server user create` (4-31). Higher = slower hashing;
# 10 is a sensible default, consider how slow the Pi is before raising it.
BCRYPT_COST=10

# ---- word sets -------------------------------------------------------------
# Each set gets a random length in this range (inclusive).
SET_MIN_WORDS=30
SET_MAX_WORDS=45

# ---- api limits ------------------------------------------------------------
# GET /api/results page size: default when no ?limit= given, and the maximum
# a client may request.
RESULTS_DEFAULT_LIMIT=20
RESULTS_MAX_LIMIT=500

# Number of recent results in the stats chart series.
STATS_SERIES_LIMIT=100
